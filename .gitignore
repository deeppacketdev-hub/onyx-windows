## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/xamarin)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
ARM64/
ARM/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Tt]estResults/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create to-do list files in the project directory
#MyTo-DoTemplates.txt
# Microsoft SQL Server files
*.mdf
*.ldf
*.ndf

# NUnit
*.visualstate

# JetBrains Rider
.idea/
*.sln.iml

# OS files
.DS_Store
Thumbs.db
