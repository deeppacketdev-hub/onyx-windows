<Application
    x:Class="OnyxWindows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:OnyxWindows.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility" />
            <converters:InstanceStateToStringConverter x:Key="InstanceStateToString" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
