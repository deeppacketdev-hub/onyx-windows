<UserControl
    x:Class="OnyxWindows.Views.Screenshots.ScreenshotsGalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:OnyxWindows.ViewModels"
    xmlns:services="using:OnyxWindows.Services"
    xmlns:converters="using:OnyxWindows.Converters"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Action Panel -->
        <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Screenshots Library" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" />
                <TextBlock Text="Browse and manage in-game captures and achievements from all instances" FontSize="13" Foreground="#8C9BAE" />
            </StackPanel>
            
            <Button Grid.Column="1"
                    Command="{Binding RefreshCommand}"
                    Background="#1C2E3F"
                    Foreground="#FFFFFF"
                    BorderBrush="#253545"
                    BorderThickness="1"
                    Padding="16,8"
                    CornerRadius="8"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Reload Gallery" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Body Area -->
        <Grid Grid.Row="1">
            <ProgressRing IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                          Foreground="#4C8AEA"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Grid>
                    <!-- Grid View of Images -->
                    <GridView ItemsSource="{Binding Screenshots}"
                              SelectedItem="{Binding SelectedScreenshot, Mode=TwoWay}"
                              SelectionMode="Single"
                              Padding="0,4"
                              HorizontalAlignment="Stretch">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" HorizontalAlignment="Stretch" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="services:ScreenshotItem">
                                <Border Width="200" 
                                        Height="150" 
                                        Background="#14212F" 
                                        BorderBrush="#253545" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Margin="0,0,12,12" 
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{x:Binding FilePath}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        
                                        <!-- Overlay gradient with stats on hover/visual -->
                                        <Grid VerticalAlignment="Bottom" Background="#B0000000" Padding="10,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{x:Binding InstanceName}" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Binding Resolution}" FontSize="10" Foreground="#8C9BAE" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Click="Delete_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#E81123" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <!-- Empty State -->
                    <StackPanel Visibility="{Binding HasNoScreenshots, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Padding="48">
                        <Ellipse Width="64" Height="64" Fill="#1C2E3F" HorizontalAlignment="Center">
                            <!-- Glyph placeholder -->
                        </Ellipse>
                        <TextBlock Text="No Screenshots Found" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        <TextBlock Text="Take some screenshots inside the game by pressing F2."
                                   Foreground="#8C9BAE"
                                   FontSize="13"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Fullscreen Zoom Lightbox View Overlay -->
        <Grid Grid.RowSpan="2" 
              x:Name="LightboxOverlay" 
              Background="#D00F1923" 
              Visibility="Collapsed" 
              PointerPressed="CloseLightbox_Click">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Zoomed Image -->
            <Image Grid.Row="0" 
                   Source="{Binding SelectedScreenshot.FilePath}" 
                   Stretch="Uniform" 
                   Margin="48" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" />

            <!-- Action Bar -->
            <Border Grid.Row="1" Background="#14212F" BorderThickness="0,1,0,0" BorderBrush="#253545" Padding="20,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedScreenshot.InstanceName}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="15" />
                        <TextBlock Text="{Binding SelectedScreenshot.FilePath}" Foreground="#8C9BAE" FontSize="12" />
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Click="CopyClipboard_Click" 
                            Background="#1C2E3F" 
                            Foreground="#FFFFFF" 
                            BorderBrush="#253545" 
                            BorderThickness="1" 
                            Padding="16,8" 
                            CornerRadius="8"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                            <TextBlock Text="Copy to Clipboard" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" 
                            Click="CloseLightbox_Click" 
                            Background="#4C8AEA" 
                            Foreground="#FFFFFF" 
                            Padding="16,8" 
                            CornerRadius="8">
                        <TextBlock Text="Close Preview" FontWeight="SemiBold" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
