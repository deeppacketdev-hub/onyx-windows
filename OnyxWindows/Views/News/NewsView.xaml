<UserControl
    x:Class="OnyxWindows.Views.News.NewsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="*" />     <!-- News Grid -->
        </Grid.RowDefinitions>

        <!-- ─── Header Section ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,16" ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="📰  Новини Minecraft"
                           FontSize="22" FontWeight="Bold"
                           Foreground="rgba(255,255,255,0.92)" />
                <TextBlock Text="Останні оновлення від Mojang Studios"
                           FontSize="12" Foreground="rgba(255,255,255,0.35)" />
            </StackPanel>

            <!-- Refresh Button -->
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Background="rgba(255,255,255,0.06)"
                    BorderBrush="rgba(255,255,255,0.1)"
                    BorderThickness="0.5"
                    CornerRadius="10"
                    Padding="14,8"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="#A594F9" />
                    <TextBlock Text="Оновити" FontSize="12" Foreground="rgba(255,255,255,0.6)" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ─── Loading State ─── -->
        <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, FallbackValue=Collapsed}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressRing Width="36" Height="36" IsActive="True" />
            <TextBlock Text="Завантаження новин..." FontSize="13" Foreground="rgba(255,255,255,0.4)" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ─── Error State ─── -->
        <Border Grid.Row="1"
                Visibility="{Binding HasError, FallbackValue=Collapsed}"
                Background="rgba(220,50,50,0.08)"
                CornerRadius="12" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="rgba(220,50,50,0.2)" BorderThickness="0.5">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="⚠️  Помилка завантаження" FontSize="14" FontWeight="SemiBold"
                           Foreground="rgba(220,100,100,0.9)" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="11"
                           Foreground="rgba(255,255,255,0.4)" TextWrapping="Wrap"
                           MaxWidth="300" HorizontalAlignment="Center" />
                <Button Content="Спробувати знову" Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center" Margin="0,8,0,0"
                        Background="rgba(255,255,255,0.06)" CornerRadius="8"
                        Foreground="rgba(255,255,255,0.6)" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- ─── News Cards Grid ─── -->
        <GridView Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="NewsItem_Click"
                  HorizontalAlignment="Stretch"
                  Padding="0">

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   ItemWidth="320"
                                   ItemHeight="280"
                                   HorizontalAlignment="Left" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,12,12" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>

            <GridView.ItemTemplate>
                <DataTemplate>
                    <!-- News Card -->
                    <Border Background="rgba(255,255,255,0.04)"
                            CornerRadius="14"
                            BorderBrush="rgba(255,255,255,0.06)"
                            BorderThickness="0.5">
                        <Grid RowDefinitions="160,*">
                            <!-- Card Image Header -->
                            <Border Grid.Row="0" CornerRadius="14,14,0,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ImageUrl}"
                                                Stretch="UniformToFill" />
                                </Border.Background>
                                <!-- Gradient overlay for text readability -->
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.4" />
                                            <GradientStop Color="#CC111318" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <Grid VerticalAlignment="Bottom" Padding="14,0,14,10">
                                        <!-- Category Badge -->
                                        <Border Background="rgba(124,109,250,0.65)"
                                                CornerRadius="6" Padding="8,3"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- Card Content -->
                            <StackPanel Grid.Row="1" Padding="14,12" Spacing="6">
                                <!-- Title -->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="rgba(255,255,255,0.88)"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Date -->
                                <TextBlock Text="{Binding FormattedDate}"
                                           FontSize="10"
                                           Foreground="rgba(255,255,255,0.3)" />

                                <!-- Excerpt -->
                                <TextBlock Text="{Binding Text}"
                                           FontSize="11"
                                           Foreground="rgba(255,255,255,0.45)"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</UserControl>
