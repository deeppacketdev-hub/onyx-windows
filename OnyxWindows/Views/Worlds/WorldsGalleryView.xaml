<UserControl
    x:Class="OnyxWindows.Views.Worlds.WorldsGalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:OnyxWindows.ViewModels"
    xmlns:services="using:OnyxWindows.Services"
    xmlns:converters="using:OnyxWindows.Converters"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Worlds Directory" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" />
                <TextBlock Text="Manage, play or clean up save directories across all installed instances" FontSize="13" Foreground="#8C9BAE" />
            </StackPanel>
            
            <Button Grid.Column="1"
                    Command="{Binding RefreshCommand}"
                    Background="#1C2E3F"
                    Foreground="#FFFFFF"
                    BorderBrush="#253545"
                    BorderThickness="1"
                    Padding="16,8"
                    CornerRadius="8"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Reload Saves" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <ProgressRing IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                          Foreground="#4C8AEA"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Grid>
                    <!-- Worlds List Grid -->
                    <GridView ItemsSource="{Binding Worlds}"
                              SelectedItem="{Binding SelectedWorld, Mode=TwoWay}"
                              SelectionMode="Single"
                              Padding="0,4"
                              HorizontalAlignment="Stretch">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" HorizontalAlignment="Stretch" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="services:WorldItem">
                                <Border Width="240" 
                                        Height="150" 
                                        Background="#14212F" 
                                        BorderBrush="#253545" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Padding="16" 
                                        Margin="0,0,12,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Title info & instance name -->
                                        <StackPanel Grid.Row="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="#4C8AEA" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Binding Name}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="15" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Binding InstanceName}" Foreground="#8C9BAE" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Footer with Date & delete options -->
                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Last Played" FontSize="10" Foreground="#8C9BAE" />
                                                <TextBlock Text="{x:Binding LastPlayed, ConverterParameter='g'}" FontSize="11" Foreground="#FFFFFF" />
                                            </StackPanel>
                                            
                                            <!-- Action Delete button -->
                                            <Button Grid.Column="1"
                                                    Click="Delete_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Width="32"
                                                    Height="32"
                                                    CornerRadius="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#E81123" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <!-- Empty State Placeholder -->
                    <StackPanel Visibility="{Binding Worlds.Count, Converter={StaticResource InverseBoolConverter}, FallbackValue=Collapsed}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Padding="48">
                        <Ellipse Width="64" Height="64" Fill="#1C2E3F" HorizontalAlignment="Center">
                            <!-- Glyph placeholder -->
                        </Ellipse>
                        <TextBlock Text="No Minecraft Worlds Found" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        <TextBlock Text="Create a new world inside the Minecraft game or import a folder manually."
                                   Foreground="#8C9BAE"
                                   FontSize="13"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
