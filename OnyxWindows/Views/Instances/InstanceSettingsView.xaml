<UserControl
    x:Class="OnyxWindows.Views.Instances.InstanceSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <Grid MaxWidth="680" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Header -->
                <RowDefinition Height="Auto" />  <!-- Name -->
                <RowDefinition Height="Auto" />  <!-- Memory -->
                <RowDefinition Height="Auto" />  <!-- Java -->
                <RowDefinition Height="Auto" />  <!-- JVM Args -->
                <RowDefinition Height="Auto" />  <!-- Resolution -->
                <RowDefinition Height="Auto" />  <!-- Fullscreen -->
                <RowDefinition Height="Auto" />  <!-- Custom Icon -->
                <RowDefinition Height="Auto" />  <!-- Action buttons -->
            </Grid.RowDefinitions>

            <!-- ─── Header ─── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24" Spacing="4">
                <TextBlock Text="⚙️  Налаштування збірки"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#EBFFFFFF" />
                <TextBlock Text="Параметри запуску, пам'ять, Java і розподіл вікна"
                           FontSize="12" Foreground="#59FFFFFF" />
            </StackPanel>

            <!-- ─── Instance Name ─── -->
            <Border Grid.Row="1" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="Назва збірки" FontSize="12" FontWeight="SemiBold"
                               Foreground="#8CFFFFFF" />
                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                             Background="#0FFFFFFF"
                             Foreground="White"
                             BorderBrush="#1AFFFFFF"
                             BorderThickness="0.5"
                             CornerRadius="8"
                             Padding="12,8"
                             FontSize="13" />
                </StackPanel>
            </Border>

            <!-- ─── RAM Allocation ─── -->
            <Border Grid.Row="2" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="🧠  Пам'ять (RAM)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#8CFFFFFF" VerticalAlignment="Center" />
                        <Border Grid.Column="1" Background="#267C6DFA"
                                CornerRadius="6" Padding="8,3">
                            <TextBlock Foreground="#A594F9" FontSize="11" FontWeight="SemiBold">
                                <Run Text="{Binding RamMB}" />
                                <Run Text=" MB" />
                            </TextBlock>
                        </Border>
                    </Grid>
                    <Slider Value="{Binding RamMB, Mode=TwoWay}"
                            Minimum="512" Maximum="16384" StepFrequency="256"
                            Foreground="#7C6DFA"
                            Background="#1AFFFFFF" />
                    <TextBlock Text="Рекомендовано: 4096 MB для модів, 2048 MB для ванілі"
                               FontSize="10" Foreground="#4CFFFFFF" />
                </StackPanel>
            </Border>

            <!-- ─── Java Path ─── -->
            <Border Grid.Row="3" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="☕  Шлях до Java (необов'язково)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#8CFFFFFF" />
                    <TextBox Text="{Binding JavaPath, Mode=TwoWay}"
                             PlaceholderText="Авто-визначення / Custom Java path..."
                             Background="#0FFFFFFF"
                             Foreground="White"
                             BorderBrush="#1AFFFFFF"
                             BorderThickness="0.5"
                             CornerRadius="8"
                             Padding="12,8"
                             FontSize="13" />
                    <TextBlock Text="Залиште порожнім для автоматичного визначення Java"
                               FontSize="10" Foreground="#4CFFFFFF" />
                </StackPanel>
            </Border>

            <!-- ─── JVM Arguments ─── -->
            <Border Grid.Row="4" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="🔧  JVM Аргументи" FontSize="12" FontWeight="SemiBold"
                               Foreground="#8CFFFFFF" />
                    <TextBox Text="{Binding JvmArgs, Mode=TwoWay}"
                             PlaceholderText="-XX:+UseG1GC -XX:+ParallelRefProcEnabled"
                             Background="#0FFFFFFF"
                             Foreground="White"
                             BorderBrush="#1AFFFFFF"
                             BorderThickness="0.5"
                             CornerRadius="8"
                             Padding="12,8"
                             FontSize="12"
                             FontFamily="Cascadia Code, Consolas"
                             AcceptsReturn="False"
                             TextWrapping="Wrap"
                             Height="60" />
                </StackPanel>
            </Border>

            <!-- ─── Game Window Resolution ─── -->
            <Border Grid.Row="5" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="🖥️  Розподіл вікна гри" FontSize="12" FontWeight="SemiBold"
                               Foreground="#8CFFFFFF" />
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,0">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Ширина" FontSize="10" Foreground="#66FFFFFF" />
                            <NumberBox Value="{Binding GameWidth, Mode=TwoWay}"
                                       PlaceholderText="854"
                                       SpinButtonPlacementMode="Compact"
                                       Minimum="320" Maximum="7680"
                                       Background="#0FFFFFFF"
                                       Foreground="White"
                                       BorderBrush="#1AFFFFFF"
                                       CornerRadius="8"
                                       FontSize="12" />
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="×" FontSize="16"
                                   Foreground="#4CFFFFFF"
                                   VerticalAlignment="Bottom"
                                   Margin="12,0,12,10" />

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Висота" FontSize="10" Foreground="#66FFFFFF" />
                            <NumberBox Value="{Binding GameHeight, Mode=TwoWay}"
                                       PlaceholderText="480"
                                       SpinButtonPlacementMode="Compact"
                                       Minimum="240" Maximum="4320"
                                       Background="#0FFFFFFF"
                                       Foreground="White"
                                       BorderBrush="#1AFFFFFF"
                                       CornerRadius="8"
                                       FontSize="12" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── Fullscreen Toggle ─── -->
            <Border Grid.Row="6" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,12"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                        <TextBlock Text="🔲  Повноекранний режим" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#8CFFFFFF" />
                        <TextBlock Text="Запускати гру у повноекранному режимі"
                                   FontSize="10" Foreground="#4CFFFFFF" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding Fullscreen, Mode=TwoWay}"
                                  OnContent="" OffContent=""
                                  VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ─── Custom Icon Path ─── -->
            <Border Grid.Row="7" Background="#0AFFFFFF" CornerRadius="12"
                    Padding="18,14" Margin="0,0,0,20"
                    BorderBrush="#0FFFFFFF" BorderThickness="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="🎨  Кастомна іконка" FontSize="12" FontWeight="SemiBold"
                               Foreground="#8CFFFFFF" />
                    <TextBox Text="{Binding CustomIconPath, Mode=TwoWay}"
                             PlaceholderText="Шлях до .png іконки (необов'язково)"
                             Background="#0FFFFFFF"
                             Foreground="White"
                             BorderBrush="#1AFFFFFF"
                             BorderThickness="0.5"
                             CornerRadius="8"
                             Padding="12,8"
                             FontSize="13" />
                </StackPanel>
            </Border>

            <!-- ─── Action Buttons ─── -->
            <Grid Grid.Row="8" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,24">
                <!-- Back / Cancel -->
                <Button Grid.Column="0" Command="{Binding CancelCommand}"
                        Background="#0FFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="0.5"
                        CornerRadius="10"
                        Padding="20,10"
                        Foreground="#99FFFFFF"
                        FontSize="13">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="13" Foreground="#80FFFFFF" />
                        <TextBlock Text="Назад" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Save -->
                <Button Grid.Column="2" Command="{Binding SaveCommand}"
                        CornerRadius="10"
                        Padding="24,10"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C6DFA" Offset="0.0" />
                            <GradientStop Color="#4C8AEA" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="13" Foreground="White" />
                        <TextBlock Text="Зберегти" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
