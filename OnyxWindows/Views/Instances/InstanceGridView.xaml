<UserControl
    x:Class="OnyxWindows.Views.Instances.InstanceGridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OnyxWindows.Models"
    xmlns:converters="using:OnyxWindows.Converters"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <converters:InstanceToEmojiConverter x:Key="EmojiConverter" />
        <converters:InstanceToCardArtBrushConverter x:Key="CardArtBrushConverter" />
        <converters:ModLoaderToBadgeBrushConverter x:Key="BadgeBrushConverter" />
        <converters:InstanceStateToStringConverter x:Key="StateConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Section header label -->
        <TextBlock Grid.Row="0"
                   Text="Всі збірки / All Instances"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#4DFFFFFF"
                   CharacterSpacing="80"
                   Margin="0,0,0,16" />

        <!-- Grid area instances cards -->
        <GridView Grid.Row="1"
                  ItemsSource="{Binding Instances}"
                  SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Padding="0">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="6" HorizontalAlignment="Stretch" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Instance">
                    <!-- High-Fidelity Bento Card exactly matching user reference -->
                    <Border Background="#1C1E24"
                            BorderBrush="#282A30"
                            BorderThickness="1"
                            CornerRadius="10"
                            Width="160"
                            Height="190"
                            Margin="0,0,12,12">
                        <Border.Resources>
                            <!-- Hover state styles -->
                            <SolidColorBrush x:Key="BorderBrushPointerOver" Color="#49427A" />
                        </Border.Resources>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="82" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Art Area with custom gradients -->
                            <Border Grid.Row="0"
                                    Background="{Binding Converter={StaticResource CardArtBrushConverter}}"
                                    CornerRadius="10,10,0,0"
                                    ClipToBounds="True">
                                <Grid>
                                    <!-- Center graphic emoji icon -->
                                    <TextBlock Text="{Binding Converter={StaticResource EmojiConverter}}"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />

                                    <!-- Top-right version-badge -->
                                    <Border Background="#90000000"
                                            CornerRadius="5"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="7">
                                        <TextBlock Text="{x:Bind MinecraftVersion}"
                                                   FontSize="10"
                                                   Foreground="#99FFFFFF" />
                                    </Border>

                                    <!-- Bottom-left loader-dot -->
                                    <Border Background="{x:Bind ModLoader, Converter={StaticResource BadgeBrushConverter}, ConverterParameter=Background}"
                                            BorderBrush="{x:Bind ModLoader, Converter={StaticResource BadgeBrushConverter}, ConverterParameter=Foreground}"
                                            BorderThickness="0.5"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Margin="7">
                                        <TextBlock Text="{x:Bind ModLoader}"
                                                   FontSize="9"
                                                   Foreground="{x:Bind ModLoader, Converter={StaticResource BadgeBrushConverter}, ConverterParameter=Foreground}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Row 1: Card Info Details -->
                            <StackPanel Grid.Row="1" Padding="8,10,8,4" Spacing="2">
                                <TextBlock Text="{x:Bind Name}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#E5FFFFFF"
                                           TextTrimming="CharacterEllipsis" />
                                
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <!-- RAM & Metadata parameters -->
                                    <TextBlock Text="RAM: " FontSize="11" Foreground="#4DFFFFFF" />
                                    <TextBlock Text="{x:Bind RamMB}" FontSize="11" Foreground="#4DFFFFFF" />
                                    <TextBlock Text=" MB" FontSize="11" Foreground="#4DFFFFFF" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Row 2: Card Footer Play Button -->
                            <Grid Grid.Row="2" Padding="10,0,10,8">
                                <Button Command="{Binding ElementName=RootGrid, Path=DataContext.PlayCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#292348"
                                        BorderBrush="#49427A"
                                        BorderThickness="1"
                                        Foreground="#A594F9"
                                        Height="26"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="6"
                                        Padding="0"
                                        FontWeight="SemiBold">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#342D5C" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#B5A4FF" />
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xF5B0;" FontSize="10" Foreground="#A594F9" />
                                        <TextBlock Text="Запустити" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</UserControl>
