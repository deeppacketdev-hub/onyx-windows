<UserControl
    x:Class="OnyxWindows.Views.Console.ConsoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:OnyxWindows.ViewModels"
    xmlns:services="using:OnyxWindows.Services"
    xmlns:converters="using:OnyxWindows.Converters"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Standard Value Converter for Logs Styling -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:LogTypeColorConverter x:Key="LogTypeColorConverter" />
    </UserControl.Resources>

    <Grid Background="#0A111A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Action Strip -->
        <Border Grid.Row="0" Background="#14212F" BorderThickness="0,0,0,1" BorderBrush="#253545" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                
                <!-- Title & Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE756;" Foreground="#8C9BAE" FontSize="14" />
                    <TextBlock Text="Developer Console Stream" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" />
                </StackPanel>

                <!-- Action Button: Clear -->
                <Button Grid.Column="1"
                        Command="{Binding ClearCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="12,6"
                        CornerRadius="6"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE75C;" FontSize="12" Foreground="#8C9BAE" />
                        <TextBlock Text="Clear Logs" Foreground="#8C9BAE" FontSize="12" />
                    </StackPanel>
                </Button>

                <!-- Action Button: Kill Process -->
                <Button Grid.Column="2"
                        Command="{Binding StopGameCommand}"
                        Background="#E81123"
                        Foreground="#FFFFFF"
                        Padding="16,6"
                        CornerRadius="6">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF3040" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                        <TextBlock Text="Force Stop Minecraft" FontWeight="SemiBold" FontSize="12" />
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- Bottom Log Text Output Grid -->
        <ListView Grid.Row="1"
                  x:Name="LogsListView"
                  ItemsSource="{Binding LogLines}"
                  SelectionMode="None"
                  Padding="16"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="MinHeight" Value="20" />
                    <Setter Property="Padding" Value="0,2" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:LogLine">
                    <Grid Margin="0,0,0,2">
                        <!-- Custom data binding & item converter colors -->
                        <TextBlock FontFamily="Consolas, Courier New, monospace"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="{x:Bind Text}"
                                   Foreground="{x:Bind Type, Converter={StaticResource LogTypeColorConverter}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
