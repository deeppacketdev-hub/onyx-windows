<UserControl
    x:Class="OnyxWindows.Views.Onboarding.OnboardingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:OnyxWindows.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <Grid Background="#0F1923" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Margin="48" Background="#14212F" BorderBrush="#253545" BorderThickness="1" CornerRadius="16" MaxWidth="600" MaxHeight="500" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Padding="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top Logo / Header Info -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="#4C8AEA" />
                        <TextBlock Text="Onyx" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" />
                    </StackPanel>
                    <TextBlock x:Name="SubtitleText" Text="Set up your custom experience in seconds" Foreground="#8C9BAE" FontSize="13" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- STEP CONTENT CONTAINERS -->
                <Grid Grid.Row="1" VerticalAlignment="Center">
                    
                    <!-- Step 1: Language selection -->
                    <StackPanel x:Name="Step1_Container" Spacing="20">
                        <TextBlock Text="Select your language" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*">
                            <Button Grid.Row="0" Grid.Column="0" Content="English (EN)" Click="Language_Selected" Tag="EN" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                            <Button Grid.Row="0" Grid.Column="1" Content="Українська (UK)" Click="Language_Selected" Tag="UK" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="0" Content="Deutsch (DE)" Click="Language_Selected" Tag="DE" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="1" Content="Español (ES)" Click="Language_Selected" Tag="ES" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                            <Button Grid.Row="2" Grid.Column="0" Content="Français (FR)" Click="Language_Selected" Tag="FR" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                            <Button Grid.Row="2" Grid.Column="1" Content="Polski (PL)" Click="Language_Selected" Tag="PL" Width="220" Margin="4" Padding="12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" HorizontalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <!-- Step 2: Account nickname creation -->
                    <StackPanel x:Name="Step2_Container" Spacing="20" Visibility="Collapsed">
                        <TextBlock Text="Choose your nickname" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        <TextBlock Text="Enter a display profile username to play offline" Foreground="#8C9BAE" FontSize="12" HorizontalAlignment="Center" />
                        
                        <TextBox x:Name="NicknameInput"
                                 Width="300"
                                 PlaceholderText="Enter nickname..."
                                 Background="#1C2E3F"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#253545"
                                 Padding="12,10"
                                 CornerRadius="8"
                                 HorizontalAlignment="Center"
                                 KeyDown="NicknameInput_KeyDown" />
                        
                        <Button Content="Continue Setup" Click="Nickname_Confirmed" Width="200" Padding="12" CornerRadius="8" Background="#4C8AEA" Foreground="#FFFFFF" HorizontalAlignment="Center" FontWeight="SemiBold">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5C9AEA" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <!-- Step 3: Theme preference & Finish -->
                    <StackPanel x:Name="Step3_Container" Spacing="20" Visibility="Collapsed">
                        <TextBlock Text="Pick your color style" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        
                        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                            <Button Content="Sleek Dark" Click="Theme_Selected" Tag="Dark" Padding="16,12" CornerRadius="8" Background="#1C2E3F" Foreground="#FFFFFF" BorderBrush="#253545" />
                            <Button Content="Light Mode" Click="Theme_Selected" Tag="Light" Padding="16,12" CornerRadius="8" Background="#FFFFFF" Foreground="#0F1923" BorderBrush="#E0E0E0" />
                            <Button Content="System default" Click="Theme_Selected" Tag="System" Padding="16,12" CornerRadius="8" Background="#2A3E50" Foreground="#FFFFFF" BorderBrush="#354A60" />
                        </StackPanel>

                        <Button Content="Begin Adventure" Click="Complete_Onboarding" Width="220" Padding="14,12" CornerRadius="8" Background="#4C8AEA" Foreground="#FFFFFF" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,16,0,0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5C9AEA" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                </Grid>

                <!-- Footer Indicators -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Ellipse x:Name="Indicator1" Width="8" Height="8" Fill="#4C8AEA" />
                    <Ellipse x:Name="Indicator2" Width="8" Height="8" Fill="#253545" />
                    <Ellipse x:Name="Indicator3" Width="8" Height="8" Fill="#253545" />
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>
